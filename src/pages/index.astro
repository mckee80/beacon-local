---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="hero-gradient relative overflow-hidden min-h-[80vh] flex items-center pt-16">
    <div class="container-max relative z-10 py-20">
      <div class="max-w-2xl">
        <span class="section-label">Websites & SEO for Pelvic Floor PT</span>
        <h1 class="mb-6">
          Patients Are Looking for You
        </h1>
        <p class="text-lg text-brand-dark-light mb-8 max-w-xl">
          I help pelvic floor PT practices get found online — with an affordable website and SEO package built for your specialty.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`${base}contact/`} class="btn btn-primary btn-lg">
            Get a Free Consultation
          </a>
          <a href={`${base}services/`} class="btn btn-outline btn-lg">
            See How It Works
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section-padding bg-surface-alt" id="services">
    <div class="container-max">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="section-label">What I Do</span>
        <h2 class="section-title">Everything Your Practice Needs Online</h2>
        <p class="section-description">
          From a custom website build to ongoing SEO and content — one person handles it all, so nothing falls through the cracks.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {siteConfig.services.map((service) => (
          <div class="service-card">
            <div class="service-icon">
              {service.icon === 'search' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              )}
              {service.icon === 'code' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              )}
              {service.icon === 'pencil' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              )}
              {service.icon === 'map' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              )}
              {service.icon === 'chart' && (
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              )}
            </div>
            <h3>{service.name}</h3>
            <p>{service.description}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href={`${base}services/`} class="btn btn-outline">
          Learn More About Services
        </a>
      </div>
    </div>
  </section>

  <!-- Why Beacon Local -->
  <section class="section-padding">
    <div class="container-max">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <span class="section-label">Why Beacon Local</span>
          <h2 class="section-title">I Only Work With Pelvic Floor PTs</h2>
          <p class="section-description max-w-2xl mx-auto">
            Most agencies treat your practice like another checkbox. I built this entire business around understanding yours.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white p-8 rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">I Know What Your Patients Search For</h3>
            <p class="text-brand-dark-light">From "pelvic floor therapy near me" to condition-specific searches like prolapse, incontinence, and postpartum recovery — I already know what drives traffic to PT practices.</p>
          </div>

          <div class="bg-white p-8 rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">Your Site Is Built Fast — and Stays Fast</h3>
            <p class="text-brand-dark-light">Every site is built on modern technology with near-perfect Lighthouse scores. Fast sites rank higher and convert more patients.</p>
          </div>

          <div class="bg-white p-8 rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">I Build It, I Optimize It, I Manage It</h3>
            <p class="text-brand-dark-light">No more coordinating between your web developer and your SEO person. One person owns the entire stack — your site and your search presence.</p>
          </div>

          <div class="bg-white p-8 rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg mb-2">One Person, Zero Runaround</h3>
            <p class="text-brand-dark-light">You work directly with me. No account managers, no handoffs, no waiting for someone to loop in the dev team. When you email, I answer.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding">
    <div class="container-max">
      <div class="cta-section max-w-4xl mx-auto">
        <h3 class="text-2xl md:text-3xl">Ready to Get Found by More Patients?</h3>
        <p class="text-lg max-w-xl mx-auto">
          Let us talk about what is holding your practice back online — and how to fix it.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${base}contact/`} class="btn btn-primary bg-brand-accent border-brand-accent hover:bg-brand-accent-dark hover:border-brand-accent-dark">
            Get Started
          </a>
          <a href={`${base}services/`} class="btn bg-transparent text-white border-white hover:bg-white hover:text-brand-primary">
            View Services
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

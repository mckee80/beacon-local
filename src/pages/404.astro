---
import BaseLayout from '@/layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page Not Found" noindex={true}>
  <section class="min-h-[70vh] flex items-center justify-center section-padding">
    <div class="text-center max-w-lg">
      <h1 class="text-6xl md:text-8xl font-heading text-brand-primary mb-4">404</h1>
      <h2 class="text-2xl md:text-3xl mb-4">Page Not Found</h2>
      <p class="text-brand-dark-light mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={base} class="btn btn-primary">
          Return Home
        </a>
        <a href={`${base}contact/`} class="btn btn-outline">
          Contact Me
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

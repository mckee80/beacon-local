---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
---

<BaseLayout
  title="Services"
  description="Custom website builds, local SEO, Google Business Profile management, and content strategy designed specifically for pelvic floor physical therapy practices."
  breadcrumbs={[{ name: 'Services', url: '/services/' }]}
>
  <!-- Hero -->
  <section class="section-padding pt-28 bg-surface-alt">
    <div class="container-max">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label">Services</span>
        <h1 class="mb-4">How Beacon Local Helps Your Practice Grow</h1>
        <p class="section-description">
          A custom website and ongoing SEO — everything your pelvic floor PT practice needs to get found by more patients online.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="section-padding">
    <div class="container-max">
      <div class="max-w-4xl mx-auto space-y-12">
        {siteConfig.services.map((service, index) => (
          <div class={`flex flex-col md:flex-row gap-8 items-start ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
            <div class="flex-shrink-0 w-16 h-16 bg-brand-primary/10 rounded-2xl flex items-center justify-center">
              <div class="w-8 h-8 text-brand-primary">
                {service.icon === 'search' && (
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                )}
                {service.icon === 'code' && (
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                )}
                {service.icon === 'pencil' && (
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                )}
                {service.icon === 'map' && (
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
                {service.icon === 'chart' && (
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                  </svg>
                )}
              </div>
            </div>
            <div class="flex-1">
              <h2 class="text-2xl mb-3">{service.name}</h2>
              <p class="text-brand-dark-light text-lg leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding pt-0">
    <div class="container-max">
      <div class="cta-section max-w-4xl mx-auto">
        <h3 class="text-2xl md:text-3xl">Ready to Get Started?</h3>
        <p class="text-lg max-w-xl mx-auto">
          Let's have a quick conversation about your practice and figure out the best path forward. No pressure, no sales pitch.
        </p>
        <a href="/contact/" class="btn btn-primary bg-brand-accent border-brand-accent hover:bg-brand-accent-dark hover:border-brand-accent-dark">
          Get a Free Consultation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About"
  description="Learn why Beacon Local focuses exclusively on building websites and managing SEO for pelvic floor physical therapy practices."
  breadcrumbs={[{ name: 'About', url: '/about/' }]}
>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}images/hero-lighthouse.jpg`} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-brand-dark/70"></div>
    </div>
    <div class="container-max relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label text-brand-accent">About</span>
        <h1 class="mb-4 text-white">Why Beacon Local Exists</h1>
        <p class="section-description text-white/80">
          I built Beacon Local for one reason: pelvic floor PTs deserve better websites and smarter SEO than what generic agencies deliver.
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="section-padding">
    <div class="container-max">
      <div class="max-w-3xl mx-auto">
        <div class="space-y-6 text-brand-dark-light text-lg leading-relaxed">
          <p>
            I come from a software background and have been building websites for years. When I built a site for a pelvic floor PT practice, I dove deep into the SEO side — what patients actually search for, how Google ranks local providers, what makes a site convert. The results were strong, and I realized most practices were either overpaying agencies for generic work or going without.
          </p>
          <p>
            That’s why I started Beacon Local. I wanted to give pelvic floor PT practices a competitive online presence at a price point that actually makes sense — not what the market will bear, but what works for both of us.
          </p>
          <p>
            Every site I build is fast, SEO-ready, and designed specifically for your specialty. And because I also manage your SEO and content, everything works together — your site, your Google Business Profile, and your search rankings.
          </p>

          <!-- Philosophy Box -->
          <div class="bg-surface-alt p-6 rounded-lg my-8 border-l-4 border-brand-primary">
            <h3 class="text-base mb-2 text-brand-primary-dark font-heading font-semibold">My Approach</h3>
            <p class="mb-2">
              I build your site, I manage your SEO, and I handle your content. One person owns the entire stack. No coordinating between a web developer and an SEO agency. No waiting on someone else to make a change.
            </p>
            <p class="mb-0">
              No jargon, no fluff, no long-term contracts. Just clear communication and measurable results for your practice.
            </p>
          </div>

          <p>
            Your website is yours — the code, the content, everything. If you ever move on, you take it with you. No hostage situations, no proprietary lock-in.
          </p>

          <p>
            That’s what the Beacon Local package is — a new website, ongoing SEO, and a content strategy that works together from day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding pt-0">
    <div class="container-max">
      <div class="cta-section max-w-4xl mx-auto">
        <h3 class="text-2xl md:text-3xl">Let's Get Your Practice Found</h3>
        <p class="text-lg max-w-xl mx-auto">
          Ready to show up when patients search for pelvic floor therapy in your area? I would love to hear about your practice.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${base}contact/`} class="btn btn-primary bg-brand-accent border-brand-accent hover:bg-brand-accent-dark hover:border-brand-accent-dark">
            Get in Touch
          </a>
          <a href={`${base}services/`} class="btn bg-transparent text-white border-white hover:bg-white hover:text-brand-primary">
            View Services
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

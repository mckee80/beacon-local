---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About"
  description="Learn why Beacon Local focuses exclusively on building websites and managing SEO for pelvic floor physical therapy practices."
  breadcrumbs={[{ name: 'About', url: '/about/' }]}
>
  <!-- Hero -->
  <section class="section-padding pt-28 bg-surface-alt">
    <div class="container-max">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label">About</span>
        <h1 class="mb-4">Why Beacon Local Exists</h1>
        <p class="section-description">
          I built Beacon Local for one reason: pelvic floor PTs deserve better websites and smarter SEO than what generic agencies deliver.
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="section-padding">
    <div class="container-max">
      <div class="max-w-3xl mx-auto">
        <div class="space-y-6 text-brand-dark-light text-lg leading-relaxed">
          <p>
            I started Beacon Local because I saw pelvic floor PTs struggling with the same problem: paying too much for generic websites that load slowly, rank poorly, and don't bring in patients.
          </p>
          <p>
            After working in SEO and web development, I realized the best results come from going deep in one niche rather than being a generalist. Pelvic floor PT is that niche. I understand your patients, your services, and what it takes to rank in your space.
          </p>
          <p>
            Every site I build uses modern static-site technology with proper schema markup, semantic HTML, and lightning-fast load times. And because I also manage your SEO and content, everything works together — your site, your Google Business Profile, and your search rankings.
          </p>

          <!-- Philosophy Box -->
          <div class="bg-surface-alt p-6 rounded-lg my-8 border-l-4 border-brand-primary">
            <h3 class="text-base mb-2 text-brand-primary-dark font-heading font-semibold">My Approach</h3>
            <p class="mb-2">
              I build your site, I manage your SEO, and I handle your content. One person owns the entire stack. No coordinating between a web developer and an SEO agency. No waiting on someone else to make a change.
            </p>
            <p class="mb-0">
              No jargon, no fluff, no long-term contracts. Just clear communication and measurable results for your practice.
            </p>
          </div>

          <p>
            Your website is yours — the code, the content, everything. If you ever move on, you take it with you. No hostage situations, no proprietary lock-in.
          </p>

          <p>
            That’s what the Beacon Local package is — a new website, ongoing SEO, and a content strategy that works together from day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding pt-0">
    <div class="container-max">
      <div class="cta-section max-w-4xl mx-auto">
        <h3 class="text-2xl md:text-3xl">Let's Get Your Practice Found</h3>
        <p class="text-lg max-w-xl mx-auto">
          Ready to show up when patients search for pelvic floor therapy in your area? I would love to hear about your practice.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${base}contact/`} class="btn btn-primary bg-brand-accent border-brand-accent hover:bg-brand-accent-dark hover:border-brand-accent-dark">
            Get in Touch
          </a>
          <a href={`${base}services/`} class="btn bg-transparent text-white border-white hover:bg-white hover:text-brand-primary">
            View Services
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

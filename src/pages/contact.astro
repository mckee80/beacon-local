---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contact"
  description="Get in touch with Sean McKee at Beacon Local for custom pelvic floor PT websites, local SEO, and Google Business Profile management."
  breadcrumbs={[{ name: 'Contact', url: '/contact/' }]}
>
  <!-- Hero -->
  <section class="section-padding pt-28 bg-surface-alt">
    <div class="container-max">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label">Contact</span>
        <h1 class="mb-4">Let's Talk About Your Practice</h1>
        <p class="section-description">
          Have a question about getting your practice found online? Reach out and I'll get back to you within one business day.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="section-padding">
    <div class="container-max">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white p-8 lg:p-12 rounded-2xl shadow-sm text-center">
          <h2 class="text-2xl mb-6">Get in Touch</h2>

          <div class="space-y-6">
            <!-- Email -->
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-dark-light mb-2">Email</h3>
              <a
                href={`mailto:${siteConfig.contact.email}`}
                class="text-brand-primary text-lg hover:text-brand-primary-dark transition-colors font-medium"
              >
                {siteConfig.contact.email}
              </a>
            </div>

            <!-- Scheduling placeholder -->
            <div class="pt-4 border-t border-surface-alt">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-dark-light mb-2">Schedule a Call</h3>
              <p class="text-brand-dark-light mb-4">
                Prefer to talk it through? Book a free 15-minute consultation.
              </p>
              <span class="inline-block text-sm text-brand-dark-light italic">
                Scheduling link coming soon
              </span>
            </div>

            <!-- What to expect -->
            <div class="pt-4 border-t border-surface-alt text-left">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-dark-light mb-4 text-center">What to Expect</h3>
              <ul class="space-y-3 text-brand-dark-light">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Response within one business day</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Free initial consultation — no obligation</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Honest assessment of your online presence</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Clear pricing with no surprises</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import { siteConfig } from '@/config/site';

const navigation = siteConfig.navigation.main;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface-warm/95 backdrop-blur-sm transition-all duration-300" id="header">
  <div class="container-max">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo.svg" alt="" class="w-8 h-8" width="32" height="32" />
        <span class="font-heading text-xl text-brand-primary leading-tight">Beacon</span>
        <span class="font-heading text-xl text-brand-dark leading-tight">Local</span>
      </a>

      <!-- Mobile menu button -->
      <button
        class="lg:hidden flex flex-col justify-center w-8 h-8 bg-transparent border-0 cursor-pointer"
        aria-label="Toggle navigation"
        aria-expanded="false"
        data-nav-toggle
      >
        <span class="hamburger block w-full h-0.5 bg-brand-dark transition-all relative before:content-[''] before:absolute before:left-0 before:-top-2 before:w-full before:h-0.5 before:bg-brand-dark before:transition-all after:content-[''] after:absolute after:left-0 after:top-2 after:w-full after:h-0.5 after:bg-brand-dark after:transition-all"></span>
      </button>

      <!-- Desktop navigation -->
      <ul class="hidden lg:flex items-center gap-8" role="menubar">
        {navigation.map((item) => (
          <li role="none">
            <a
              href={item.href}
              class="nav-link text-sm font-medium text-brand-dark uppercase tracking-wide relative hover:text-brand-primary transition-colors after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-brand-accent after:transition-all hover:after:w-full"
              role="menuitem"
            >
              {item.name}
            </a>
          </li>
        ))}
        <li role="none">
          <a href="/contact/" class="btn btn-primary" role="menuitem">
            Get Started
          </a>
        </li>
      </ul>

      <!-- Mobile navigation -->
      <ul
        class="nav-menu fixed top-16 left-0 right-0 bg-white flex-col p-8 gap-4 shadow-lg transform -translate-y-full opacity-0 invisible transition-all duration-300 lg:hidden"
        data-nav-menu
        role="menu"
      >
        {navigation.map((item) => (
          <li role="none">
            <a
              href={item.href}
              class="block py-2 text-brand-dark font-medium text-sm uppercase tracking-wide hover:text-brand-primary transition-colors"
              role="menuitem"
            >
              {item.name}
            </a>
          </li>
        ))}
        <li role="none">
          <a href="/contact/" class="btn btn-primary inline-block mt-2" role="menuitem">
            Get Started
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  @reference "../../styles/global.css";

  .nav-menu.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  [data-nav-toggle][aria-expanded="true"] .hamburger {
    background-color: transparent;
  }

  [data-nav-toggle][aria-expanded="true"] .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  [data-nav-toggle][aria-expanded="true"] .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  .header-scrolled {
    @apply shadow-sm;
  }
</style>

<script>
  const toggle = document.querySelector('[data-nav-toggle]');
  const menu = document.querySelector('[data-nav-menu]');
  const header = document.getElementById('header');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    menu?.classList.toggle('active');
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('active');
    });
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
  });
</script>
